# Supabase — obter em https://supabase.com/dashboard/project/<project>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe — obter em https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# EAS — preencher após rodar `eas init` (o projectId aparece no app.json)
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Anthropic (Duo AI) — obter em https://console.anthropic.com/settings/keys
# ⚠️ Nunca usar prefixo EXPO_PUBLIC_ — esta chave só vai nas Supabase Edge Functions (secrets)
# Configurar via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...
